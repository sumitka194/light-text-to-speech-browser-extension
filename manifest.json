{
  "manifest_version": 3,
  "name": "Text to speech Lite",
  "version": "1.0",
  "description": "Reads webpage text aloud",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}